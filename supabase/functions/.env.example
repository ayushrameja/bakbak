# Copy this file to a git-ignored local file before serving the function.
# Production values belong in Supabase Edge Function secrets.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=replace-locally
LIVEKIT_API_SECRET=replace-locally

# Shared only by GitHub Actions and the protected system-events function.
# Generate a high-entropy value; never expose it through a VITE_* variable.
BAKBAK_SYSTEM_EVENTS_SECRET=replace-with-a-random-system-events-secret

# Optional comma-separated origins. Authentication remains the security boundary.
# Tauri origins differ by platform, so these local values are permitted by default.
BAKBAK_ALLOWED_ORIGINS=tauri://localhost,http://tauri.localhost,http://localhost:1420
