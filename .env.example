# The mock app works with no credentials. Set this to "live" only after
# configuring Supabase and deploying the database migration and Edge Function.
VITE_DATA_MODE=mock

# Values prefixed with VITE_ are public and are embedded in desktop bundles.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud

# Never add LIVEKIT_API_SECRET, SUPABASE_SERVICE_ROLE_KEY, or any other secret
# to this file. Those belong in Supabase Edge Function secrets only.
