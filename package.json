{
  "name": "bakbak",
  "private": true,
  "version": "0.14.0",
  "packageManager": "pnpm@11.3.0",
  "description": "A private voice, text, and soundboard desktop space for close friends.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm typecheck && vite build",
    "typecheck": "tsc --noEmit --pretty false && tsc --noEmit --pretty false -p tsconfig.node.json",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audio:generate": "node scripts/generate-interface-sounds.mjs",
    "ffmpeg:build": "bash scripts/build-soundboard-ffmpeg-core.sh",
    "test": "vitest run && node --test scripts/*.test.mjs",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "security:scan": "node scripts/check-bundle-secrets.mjs",
    "version:check": "node scripts/set-version.mjs --check",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm version:check && pnpm build && pnpm security:scan",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:build:local": "tauri build --bundles app --config src-tauri/tauri.local.conf.json"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "0.12.15",
    "@ffmpeg/util": "0.12.2",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/league-gothic": "^5.2.8",
    "@jitsi/rnnoise-wasm": "0.2.1",
    "@supabase/supabase-js": "^2.110.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "livekit-client": "^2.20.1",
    "lucide-react": "^1.24.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^7.0.4",
    "vitest": "^4.1.10"
  }
}
